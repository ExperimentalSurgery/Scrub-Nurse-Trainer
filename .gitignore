
.plastic/*
ignore.conf
# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
GreifbAR_OTAToolpicker/[Ll]ibrary/
GreifbAR_OTAToolpicker/[Tt]emp/
GreifbAR_OTAToolpicker/[Oo]bj/
GreifbAR_OTAToolpicker/[Bb]uild/
GreifbAR_OTAToolpicker/[Bb]uilds/
GreifbAR_OTAToolpicker/[Ll]ogs/
GreifbAR_OTAToolpicker/[Uu]ser[Ss]ettings/
GreifbAR_OTAToolpicker/PointClouds/
GreifbAR_OTAToolpicker/Assets/Samples/
GreifbAR_OTAToolpicker/Assets/Samples.meta
GreifbAR_OTAToolpicker/Assets/SamplesResources/
GreifbAR_OTAToolpicker/Assets/SamplesResources.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
GreifbAR_OTAToolpicker/[Mm]emoryCaptures/

# Recordings can get excessive in size
GreifbAR_OTAToolpicker/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
GreifbAR_OTAToolpicker/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
GreifbAR_OTAToolpicker/.vs/

# Gradle cache directory
GreifbAR_OTAToolpicker/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
GreifbAR_OTAToolpicker/ExportedObj/
GreifbAR_OTAToolpicker/.consulo/
GreifbAR_OTAToolpicker/*.csproj
GreifbAR_OTAToolpicker/*.unityproj
GreifbAR_OTAToolpicker/*.sln
GreifbAR_OTAToolpicker/*.suo
GreifbAR_OTAToolpicker/*.tmp
GreifbAR_OTAToolpicker/*.user
GreifbAR_OTAToolpicker/*.userprefs
GreifbAR_OTAToolpicker/*.pidb
GreifbAR_OTAToolpicker/*.booproj
GreifbAR_OTAToolpicker/*.svd
GreifbAR_OTAToolpicker/*.pdb
GreifbAR_OTAToolpicker/*.mdb
GreifbAR_OTAToolpicker/*.opendb
GreifbAR_OTAToolpicker/*.VC.db

# Unity3D generated meta files
GreifbAR_OTAToolpicker/*.pidb.meta
GreifbAR_OTAToolpicker/*.pdb.meta
GreifbAR_OTAToolpicker/*.mdb.meta

# Unity3D generated file on crash reports
GreifbAR_OTAToolpicker/sysinfo.txt

# Builds
GreifbAR_OTAToolpicker/*.apk
GreifbAR_OTAToolpicker/*.aab
GreifbAR_OTAToolpicker/*.unitypackage
GreifbAR_OTAToolpicker/*.app

# Crashlytics generated file
GreifbAR_OTAToolpicker/crashlytics-build.properties

# Packed Addressables
GreifbAR_OTAToolpicker/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
