  m_TableData:
  - m_Id: 399284019200
    m_Localized: "Willkommen in der Anwendung. Benutze deinen Finger, um einen der
      Kn\xF6pfe zu dr\xFCcken. Du kannst mit allen Elementen interagieren, die blau
      sind.\r\n\r\n\r\n\r\n\r\n\r\n"
    m_Metadata:
      m_Items: []
  - m_Id: 399300796416
    m_Localized: "Benutze deinen Finger, um einen der Kn\xF6pfe zu dr\xFCcken"
    m_Metadata:
      m_Items: []
  - m_Id: 399300796417
    m_Localized: "Willkommen zur\xFCck. W\xE4hle ein Level aus, das du \xFCben m\xF6chtest"
    m_Metadata:
      m_Items: []
  - m_Id: 399300796418
    m_Localized: "Hier kannst du zwischen den Leveln w\xE4hlen, um gezielt Identifikation,
      Vorbereiten und Anreichen zu \xFCben. Beginne am besten mit Level 1: Identifikation
      im Lernmodus"
    m_Metadata:
      m_Items: []
  - m_Id: 399300796419
    m_Localized: "Benutze deinen Finger, um einen der Kn\xF6pfe zu dr\xFCcken"
    m_Metadata:
      m_Items: []
  - m_Id: 399300796420
    m_Localized: Toll, du hast einen neuen Modus freigeschaltet!
